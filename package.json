{
  "name": "chounting",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps chromium",
    "agent:floor": "vitest run tests/integration/unbalancedJournalEntry tests/integration/lockedPeriodRejection tests/integration/crossOrgRlsIsolation tests/integration/serviceMiddlewareAuthorization tests/integration/reversalMirror",
    "agent:validate": "pnpm typecheck && pnpm test:no-hardcoded-urls && pnpm agent:floor",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:migrate": "supabase migration up --local",
    "db:reset": "supabase db reset --local",
    "db:generate-types": "supabase gen types typescript --local > src/db/types.ts",
    "db:seed": "psql postgresql://postgres:postgres@127.0.0.1:54322/postgres -f src/db/seed/dev.sql",
    "db:seed:auth": "dotenv -e .env.local -- tsx scripts/seed-auth-users.ts",
    "db:seed:all": "pnpm db:seed:auth && pnpm db:seed",
    "db:reset:clean": "pnpm db:reset && docker restart supabase_kong_chounting && sleep 3 && pnpm db:seed:all",
    "test:no-hardcoded-urls": "! grep -rn 'localhost:54321\\|127.0.0.1:54321' tests/ src/",
    "verify-audit-coverage": "tsx scripts/audit/verifyAuditCoverage.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@hookform/resolvers": "^5.2.2",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.103.0",
    "bcryptjs": "^3.0.3",
    "decimal.js": "^10.6.0",
    "next": "^15.0.0",
    "next-intl": "^3.20.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.72.1",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^2.0.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "^15.0.0",
    "supabase": "^1.200.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^2.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}