# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
# claude code
# Directory contents ignored by default; un-ignore the committed project
# config so it can be reviewed like CI config. settings.local.json is also
# gitignored globally via ~/.gitignore_global. Note the pattern is `.claude/*`
# (contents) not `.claude/` (directory) — git can't re-include children of an
# excluded directory.
.claude/*
!.claude/settings.json

# playwright e2e — storageState cookies are credentials
tests/e2e/.auth/
# playwright reports / results
/playwright-report/
/test-results/

# runtime log capture — the historical `pnpm dev 2>&1 | tee "logs/..."` pattern
# was the direct cause of a Next.js watcher feedback storm (Session 8 C6-pre
# finding; the prereq doc at docs/07_governance/ec-2-prompt-set.md now points
# log capture at /tmp/ instead). /logs/ stays ignored as defense-in-depth in
# case the old pattern re-appears in a future prereq.
/logs/

# Session coordination — lock file is per-session, not tracked
.coordination/session-lock.json
